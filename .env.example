# ---- MagickUtils environment ----
# Copy to .env.local (local dev) or .env (Docker) and fill in. With these unset,
# the app runs on seeded MOCK data (UI fully works); set them to wire the backend.
#
# Two classes of variable:
#   • Server-only vars (everything except NEXT_PUBLIC_*) are read at RUNTIME —
#     provide via the container env (compose env_file / docker run --env-file).
#   • NEXT_PUBLIC_* vars are inlined into the client bundle at BUILD time — they
#     must be set when the image is built (compose passes them as build args;
#     with a plain `docker build`, pass --build-arg).

# Active whitelabel brand — the pack under brands/<id>/ (brand.config.json +
# logo.png) that the UI renders. Resolved at RUNTIME, so one image whitelabels
# per deployment with no rebuild. Defaults to magickvoice. See brands/README.md.
BRAND=magickvoice

# magick-master (customer-facing platform API). Required for auth + live data.
MAGICK_MASTER_BASE_URL=

# Encrypted session cookie secret (>= 32 chars). Required for auth.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=
# Optional: override the session cookie name.
# SESSION_COOKIE_NAME=mu_session

# MongoDB (durable state: cached batches, normalized records, jobs, aggregates, insights).
# Atlas SRV URI — allowlist the server's public IP in Atlas (Network Access).
MONGODB_URI=
MONGODB_DB=magickutils

# Pluggable LLM (AI insights + chat). provider = openai-compatible | anthropic
# openai-compatible covers DeepSeek / Kimi(Moonshot) / OpenRouter / NVIDIA NIM /
# self-hosted vLLM/Ollama.
#   • LLM_BASE_URL must be the API ROOT — the SDK appends "/chat/completions".
#     (e.g. https://integrate.api.nvidia.com/v1  — NOT ".../v1/chat/completions")
#   • LLM_API_KEY is the RAW key, with NO "Bearer " prefix (the SDK adds it).
LLM_PROVIDER=openai-compatible
LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=

# Firebase web config (client SDK — used by the login screen to obtain an id_token).
# BUILD-TIME: baked into the client bundle during `next build`.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── OpenTelemetry logging (Grafana Cloud) ──
# Logs-only export. When OTEL_ENABLED is not "true" or the endpoint is unset,
# logs go to stdout only (pretty in dev, JSON in prod).
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-<region>.grafana.net/otlp
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instanceId:apiToken)>
# OTEL_SERVICE_NAME=magick-utils
# OTEL_ENVIRONMENT=production
# LOG_LEVEL=info
